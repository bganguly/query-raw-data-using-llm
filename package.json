{
  "name": "h1b-lca-parquet-pipeline",
  "private": true,
  "version": "0.1.0",
  "scripts": {
    "fetch:official-data": "python3 scripts/fetch_official_h1b_data.py",
    "build:parquet": "python3 scripts/build_parquet_from_official_csv.py",
    "pipeline:run": "npm run fetch:official-data && npm run build:parquet",
